                <TypeName>XdrEndpointDeviceLiveResponseScheduledTaskRow</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader><Label>DeviceName</Label><Width>28</Width></TableColumnHeader>
                    <TableColumnHeader><Label>TaskId</Label><Width>48</Width></TableColumnHeader>
                    <TableColumnHeader><Label>Enabled</Label><Width>8</Width></TableColumnHeader>
