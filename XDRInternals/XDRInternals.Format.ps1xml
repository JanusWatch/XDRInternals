                            <TableColumnItem><PropertyName>IsEnabled</PropertyName></TableColumnItem>
                            <TableColumnItem><PropertyName>Principal</PropertyName></TableColumnItem>
                            <TableColumnItem><ScriptBlock>if ($_.Arguments) { '{0} {1}' -f $_.ActionPath, $_.Arguments } else { $_.ActionPath }</ScriptBlock></TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>
